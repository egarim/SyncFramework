@page "/"
@rendermode InteractiveServer
@using BIT.Data.Sync.Server
@using BIT.Data.Sync
@inject ISyncFrameworkServer SyncServer

<h1 class="mb-4"><i class="bi bi-server me-2"></i>Nodes</h1>

@if (!nodes.Any())
{
    <div class="alert alert-info">
        No nodes registered yet. <a href="/nodes/add">Add one</a>.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Node ID</th>
                        <th>Store Type</th>
                        <th>Deltas</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var node in nodes)
                    {
                        <tr>
                            <td class="align-middle">
                                <span class="badge bg-secondary me-2"><i class="bi bi-circle-fill text-success"></i></span>
                                <strong>@node.NodeId</strong>
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-info text-dark">@node.DeltaStore?.GetType().Name</span>
                            </td>
                            <td class="align-middle">@GetDeltaCount(node)</td>
                            <td class="align-middle">
                                <a href="/nodes/@node.NodeId/replay" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-play-circle me-1"></i>Replay
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-3">
    <a href="/nodes/add" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Node
    </a>
    <button class="btn btn-outline-secondary ms-2" @onclick="Refresh">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
    </button>
</div>

@code {
    private List<IServerSyncEndpoint> nodes = new();

    protected override void OnInitialized()
    {
        LoadNodes();
    }

    private void LoadNodes()
    {
        nodes = SyncServer.Nodes?.ToList() ?? new();
    }

    private void Refresh() => LoadNodes();

    private string GetDeltaCount(IServerSyncEndpoint node)
    {
        try
        {
            var count = node.DeltaStore?.GetDeltaCountAsync(string.Empty, string.Empty, default).Result;
            return count?.ToString() ?? "—";
        }
        catch
        {
            return "—";
        }
    }
}
